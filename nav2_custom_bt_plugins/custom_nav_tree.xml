<root main_tree_to_execute="MainTree" BTCPP_format="3">
  <BehaviorTree ID="MainTree">

    <ReactiveFallback>

      <!-- Priority 1: Low battery -> return to dock -->
      <Sequence>
        <BatteryMonitor threshold="0.15"/>
        <ReturnToDock dock_pose="0.0;0.0;0.0"/>
        <RecoveryNode number_of_retries="3" name="DockRecovery">
          <PipelineSequence>
            <ComputePathToPose goal="{goal}" path="{path}" planner_id="GridBased"/>
            <FollowPath path="{path}" controller_id="FollowPath"/>
          </PipelineSequence>
          <Sequence>
            <ClearEntireCostmap name="ClearGlobalCostmap-Dock"
              service_name="/global_costmap/clear_entirely_global_costmap"/>
            <ClearEntireCostmap name="ClearLocalCostmap-Dock"
              service_name="/local_costmap/clear_entirely_local_costmap"/>
          </Sequence>
        </RecoveryNode>
      </Sequence>

      <!-- Priority 2: Normal navigation with safety checks -->
      <Sequence>
        <!-- CrowdStop returns SUCCESS when safe (density below threshold), -->
        <!-- FAILURE when too crowded (density above threshold) -->
        <CrowdStop density_threshold="0.7" proximity_distance="1.5"/>

        <ObstacleSlowdown distance="0.6">
          <RecoveryNode number_of_retries="3" name="NavigateRecovery">
            <PipelineSequence>
              <ComputePathToPose goal="{goal}" path="{path}" planner_id="GridBased"/>
              <FollowPath path="{path}" controller_id="FollowPath"/>
            </PipelineSequence>
            <Sequence>
              <ClearEntireCostmap name="ClearGlobalCostmap"
                service_name="/global_costmap/clear_entirely_global_costmap"/>
              <ClearEntireCostmap name="ClearLocalCostmap"
                service_name="/local_costmap/clear_entirely_local_costmap"/>
            </Sequence>
          </RecoveryNode>
        </ObstacleSlowdown>
      </Sequence>

    </ReactiveFallback>

  </BehaviorTree>

  <!-- Added For Groot ... Modify if any problems occur-->
  <TreeNodesModel>
    
    <!-- Conditions-->
    <Condition ID="BatteryMonitor">
      <input_port name="threshold" type="double" default="0.15"/>
    </Condition>


    <Condition ID="CrowdStop">
      <input_port name="density_threshold" type="double" default="0.0"/>
      <input_port name="proximity_distance" type="double" default="1.0"/>
    </Condition>

    <!-- Actions-->
    <Action ID="ReturnToDock">
      <input_port name="dock_pose" type="std::string"/> <!-- adjust type as needed -->
    </Action>

    <Action ID="ComputePathToPose">
      <input_port name="goal" type="PoseStamped"/>
      <input_port name="planner_id" type="std::string" default="GridBased"/>
      <output_port name="path" type="nav_msgs::msg::Path"/>
    </Action>


    <Action ID="FollowPath">
      <input_port name="path" type="nav_msgs::msg::Path"/>
      <input_port name="controller_id" type="std::string" default="FollowPath"/>
    </Action>

    <Action ID="ClearEntireCostmap">
      <input_port name="service_name" type="std::string"/>
    </Action>

    <!--Decorator-->
    <Decorator ID="ObstacleSlowdown">
      <input_port name="distance" type="double" default="0.6"/>
    </Decorator>

    <!-- Control Nodes-->
    <Control ID="RecoveryNode">
      <input_port name="number_of_retries" type="int" default="3"/>
    </Control>
    <Control ID="PipelineSequence"/>

  </TreeNodesModel>
</root>
