<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">

    <Fallback>

      <Sequence>
        <BatteryMonitor threshold="0.15"/>
        <ReturnToDock dock_pose="{dock}"/>
      </Sequence>

      <PipelineSequence>
        <CrowdStop density_threshold="0.8"/>
        <ObstacleSlowdown distance="0.6"/>
        <ComputePathToPose/>
        <FollowPath/>
      </PipelineSequence>

    </Fallback>

  </BehaviorTree>
</root>